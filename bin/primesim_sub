#!/usr/bin/env bash
#
# MockLSF primesim_sub — PrimeSim 잡 제출 wrapper (bash).
# 받은 인자를 그대로 mocklsf 의 bsub 에 전달하고, 그 출력을 그대로 통과시킨다.
#
set -eo pipefail

# 항상 같은 bin 의(mocklsf) bsub 만 호출한다. PATH 의 실제 bsub 는 쓰지 않는다.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BSUB="$SCRIPT_DIR/bsub"

exec "$BSUB" "$@"
